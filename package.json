{
  "name": "ps-ui-toolkit",
  "version": "0.0.0",
  "author": "Cumulocity UI Guild, @dirk-peter-c8y",
  "license": "Apache-2.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "config": {},
  "keywords": [
    "cumulocity",
    "cumulocity-package",
    "cumulocity-iot",
    "cumulocity-ui-plugin",
    "cumulocity-ui-widget",
    "cumulocity-ui-guild"
  ],
  "scripts": {
    "build": "run-s build:*",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --quiet --fix",
    "--pre/post-----------": "--------------------",
    "prebuild": "pnpm run clean",
    "--tools--------------": "--------------------",
    "generate:scripts": "node tools/generate-scripts.js",
    "generate:assets": "node tools/generate-assets.js",
    "clean": "rimraf dist",
    "--shortcuts----------": "--------------------",
    "_serve": "from-env ng serve -u %C8Y_BASEURL --shell %C8Y_SHELL_TARGET",
    "_postbuild": "node tools/postbuild.js",
    "--locals-------------": "--------------------",
    "ng": "ng",
    "eslint": "eslint",
    "--e2e----------------": "--------------------",
    "e2e:run": "pnpm -C test exec -- cypress run --browser chrome",
    "e2e:open": "pnpm -C test exec -- cypress open",
    "e2e:run:favorites-manager": "pnpm -C test exec -- cypress run --browser chrome --config-file config/favorites-manager.config.ts",
    "e2e:run:reminder": "pnpm -C test exec -- cypress run --browser chrome --config-file config/reminder.config.ts",
    "e2e:run:kpi-widget": "pnpm -C test exec -- cypress run --browser chrome --config-file config/kpi-widget.config.ts",
    "e2e:run:energy-consumption-widget": "pnpm -C test exec -- cypress run --browser chrome --config-file config/energy-consumption-widget.config.ts",
    "e2e:run:release-notes": "pnpm -C test exec -- cypress run --browser chrome --config-file config/release-notes.config.ts",
    "e2e:run:operations-widget": "pnpm -C test exec -- cypress run --browser chrome --config-file config/operations-widget.config.ts",
    "e2e:run:tenant-option-management": "pnpm -C test exec -- cypress run --browser chrome --config-file config/tenant-option-management.config.ts",
    "e2e:open:favorites-manager": "pnpm -C test exec -- cypress open --config-file config/favorites-manager.config.ts",
    "e2e:open:release-notes": "pnpm -C test exec -- cypress open --config-file config/release-notes.config.ts",
    "--generated----------": "--------------------",
    "build:shared": "ng build shared",
    "serve:reminder": "pnpm run _serve plugin.reminder",
    "build:reminder": "ng build plugin.reminder",
    "test:reminder": "pnpm --filter cumulocity-reminder-plugin run test",
    "serve:kpi-widget": "pnpm run _serve plugin.kpi-widget",
    "build:kpi-widget": "ng build plugin.kpi-widget",
    "test:kpi-widget": "pnpm --filter cumulocity-kpi-aggregator-widget-plugin run test",
    "serve:release-notes": "pnpm run _serve plugin.release-notes",
    "build:release-notes": "ng build plugin.release-notes",
    "test:release-notes": "pnpm --filter cumulocity-release-notes-plugin run test",
    "serve:energy-consumption-widget": "pnpm run _serve plugin.energy-consumption-widget",
    "build:energy-consumption-widget": "ng build plugin.energy-consumption-widget",
    "test:energy-consumption-widget": "pnpm --filter cumulocity-energy-consumption-widget-plugin run test",
    "serve:favorites-manager": "pnpm run _serve plugin.favorites",
    "build:favorites-manager": "ng build plugin.favorites",
    "serve:tenant-option-management": "pnpm run _serve plugin.tenant-option-management",
    "build:tenant-option-management": "ng build plugin.tenant-option-management",
    "test:tenant-option-management": "pnpm --filter cumulocity-tenant-option-management-plugin run test",
    "serve:operations-widget": "pnpm run _serve plugin.operations-widget",
    "build:operations-widget": "ng build plugin.operations-widget",
    "test:operations-widget": "pnpm --filter cumulocity-operations-widget-plugin run test"
  },
  "dependencies": {
    "@angular/animations": "^20.2.14",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-browser-dynamic": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/upgrade": "^20.3.16",
    "@c8y/bootstrap": "1023.14.132",
    "@c8y/client": "1023.14.132",
    "@c8y/html-repo": "1023.14.132",
    "@c8y/ng1-modules": "1023.14.132",
    "@c8y/ngx-components": "1023.14.132",
    "@c8y/style": "1023.14.132",
    "angular": "1.8.3",
    "dotenv": "^17.0.1",
    "monaco-editor": "~0.53.0",
    "ngx-bootstrap": "20.0.2",
    "rxjs": "7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin-template": "^19.2.1",
    "@angular-eslint/template-parser": "^19.2.1",
    "@angular/build": "^20.3.16",
    "@angular/cli": "^20.3.16",
    "@angular/compiler-cli": "^20.3.0",
    "@c8y/devkit": "1023.14.132",
    "@c8y/options": "1023.14.132",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.13",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "from-env": "^1.1.4",
    "jasmine-core": "~5.9.0",
    "jest": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "less": "^4.2.0",
    "ng-packagr": "^21.2.2",
    "npm-run-all": "^4.1.5",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "globals": "14.0.0"
  },
  "pnpm": {
    "overrides": {
      "globals": "14.0.0"
    }
  }
}
